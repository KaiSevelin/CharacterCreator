<form class="skilltree-chargen flexcol" autocomplete="off">

    <header class="chargen-header flexrow">
        <h2 class="chargen-title">
            <i class="fas fa-scroll"></i>
            The Life of {{actorName}}
        </h2>

        <div class="chargen-counters">
            <span class="tag">
                <i class="fas fa-hourglass-half"></i>
                Global: {{state.remainingGlobal}}
            </span>
        </div>
    </header>

    {{#if currentTableName}}
    <section class="chargen-stage">
        <h3 class="chargen-stage-title">{{currentTableName}}</h3>
    </section>
    {{/if}}

    {{#if currentTableDescription}}
    <section class="chargen-table-intro">
        <div class="table-description">{{{currentTableDescription}}}</div>
    </section>
    {{/if}}

    <section class="chargen-cards">
        {{#each cards}}
        <article class="chargen-card {{this.cardClass}} {{#if this.masked}}is-veiled{{/if}}"
                 data-index="{{@index}}"
                 title="{{this.tooltip}}"
                 style='--cg-cover: url("{{this.img}}"); --cg-back: url("{{../backImg}}");'>
            <div class="card-cover" aria-label="{{this.title}}">
                <div class="card-flip">
                    <div class="card-face card-front" role="img" aria-label="{{this.title}}"></div>
                    <div class="card-face card-back" role="img" aria-label="Card back"></div>
                </div>
            </div>

            <header class="card-header">
                <h3 class="card-title">{{this.title}}</h3>
                {{#if this.badges.length}}
                <div class="card-badges" aria-label="Card hints">
                    {{#each this.badges}}
                    <span class="card-badge is-{{this.tone}}" title="{{this.detail}}">{{this.label}}</span>
                    {{/each}}
                </div>
                {{/if}}
            </header>

            {{#if this.text}}
            <p class="card-text">{{this.text}}</p>
            {{/if}}
        </article>
        {{/each}}
    </section>

    {{#if reveal}}
    <section class="chargen-reveal">
        {{#unless reveal.isDeferred}}
        {{#unless reveal.isTransitionInterstitial}}
        <h3 class="reveal-title">Rolled Effects</h3>
        <ul class="reveal-list">
            {{#each reveal.lines}}
            <li>{{this}}</li>
        {{/each}}
        </ul>
        {{#if reveal.nextName}}
        <p class="reveal-next">Next: {{#if reveal.nextDetail}}{{reveal.nextDetail}}{{else}}{{reveal.nextName}}{{/if}}</p>
        {{else}}
        <p class="reveal-next">This path ends here.</p>
        {{/if}}
        <div class="chargen-reveal-actions">
            <button type="button" data-action="continue" class="primary-action">
                <i class="fas fa-forward"></i> Continue
            </button>
        </div>
        {{/unless}}
        {{/unless}}
    </section>
    {{/if}}

    {{#if reveal.isTransitionInterstitial}}
    <div class="transition-overlay" data-action="continue" role="button" tabindex="0" aria-label="Continue to the next chapter">
        <div class="deferred-intertitle transition-intertitle">
            <div class="deferred-intertitle__frame transition-intertitle__frame">
                {{#if reveal.image}}
                <div class="deferred-card-art transition-card-art">
                    <img src="{{reveal.image}}" alt="{{reveal.title}}">
                </div>
                {{/if}}
                {{#if reveal.transitionModeLabel}}
                <p class="transition-kind">{{reveal.transitionModeLabel}}</p>
                {{/if}}
                <h3 class="reveal-title deferred-title transition-title">Your Life Turns</h3>
                {{#if reveal.fromTableName}}
                <p class="transition-path">{{reveal.fromTableName}} &rarr; {{reveal.nextName}}</p>
                {{/if}}
                {{#if reveal.title}}
                <p class="deferred-origin transition-origin">After {{reveal.title}}</p>
                {{/if}}
                {{#if revealTransitionText}}
                <p class="reveal-text deferred-text transition-text">{{revealTransitionText}}</p>
                {{else}}
                {{#if reveal.nextDetail}}
                <p class="reveal-text deferred-text transition-text">{{reveal.nextDetail}}</p>
                {{/if}}
                {{/if}}
                {{#if reveal.lines}}
                <ul class="deferred-effects transition-effects">
                    {{#each reveal.lines}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}
                <p class="deferred-dismiss">Click to continue</p>
            </div>
        </div>
    </div>
    {{/if}}

    {{#if reveal.isDeferred}}
    <div class="deferred-overlay" data-action="continue" role="button" tabindex="0" aria-label="Continue past deferred reveal">
        <div class="deferred-intertitle">
            <div class="deferred-intertitle__frame">
                {{#if reveal.image}}
                <div class="deferred-card-art">
                    <img src="{{reveal.image}}" alt="{{reveal.title}}">
                </div>
                {{/if}}
                <h3 class="reveal-title deferred-title">{{reveal.title}}</h3>
                {{#if reveal.originLine}}
                <p class="deferred-origin">{{reveal.originLine}}</p>
                {{/if}}
                {{#if reveal.text}}
                <p class="reveal-text deferred-text">{{{revealDeferredHtml}}}</p>
                {{/if}}
                {{#if revealDeferredLines}}
                <ul class="deferred-effects">
                    {{#each revealDeferredLines}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}
                <p class="deferred-dismiss">Click to continue</p>
            </div>
        </div>
    </div>
    {{/if}}

    <section class="chargen-bio">
        {{#if compiledBio.length}}
        <details open>
            <summary>
                <i class="fas fa-feather-pointed"></i>
                Life Summary
            </summary>
            <div class="chargen-bio-summary">
                {{#each compiledBio}}
                <p>{{this}}</p>
                {{/each}}
            </div>
        </details>
        {{/if}}
        <details>
            <summary>
                <i class="fas fa-book-open"></i>
                Biography so far
            </summary>
            <ul>
                {{#each bio}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </details>
    </section>

    <section class="chargen-tables">
        <details>
            <summary>
                <i class="fas fa-table"></i>
                Relevant tables and usage
            </summary>
            <div class="table-wrap">
                <table class="cg-table-list">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Use</th>
                            <th>Table</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each relevantTables}}
                        <tr>
                            <td>{{this.role}}</td>
                            <td>{{this.use}}</td>
                            <td title="{{this.ref}}">{{this.tableName}}</td>
                            <td>
                                {{#if this.ok}}OK{{else}}Missing{{/if}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </details>
    </section>

    <footer class="sheet-footer flexrow chargen-footer">
        <button type="button" data-action="table-list">
            <i class="fas fa-list-check"></i> Validation List
        </button>
        <button type="button" data-action="reroll">
            <i class="fas fa-dice"></i> Reroll Options
        </button>
        <button type="button" data-action="finish" class="primary-action">
            <i class="fas fa-flag-checkered"></i> Finish
        </button>
    </footer>

</form>
